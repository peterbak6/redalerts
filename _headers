# dates.json is the app's entry point — must always be fresh so first-time
# visitors (no prior cache) land on the correct latest date.
/red-alert/dates.json
  Cache-Control: no-cache

# Daily JSON files — max-age=10800 matches the 3h cron schedule and keeps
# history scrubbing fast (served from browser cache without roundtrips).
# today's and yesterday's files can be rewritten; older ones are immutable.
/red-alert/*
  Cache-Control: public, max-age=10800

# Static real-data files — never change
/real-data/*
  Cache-Control: public, max-age=31536000, immutable

# Vite-fingerprinted JS/CSS assets — immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# RTL text plugin — static library, immutable
/mapbox-gl-rtl-text.js
  Cache-Control: public, max-age=31536000, immutable

# HTML entry point — short cache so deploys propagate quickly
/index.html
  Cache-Control: public, max-age=0, must-revalidate
