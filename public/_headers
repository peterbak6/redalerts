# dates.json is the app's entry point — must always be fresh so first-time
# visitors (no prior cache) land on the correct latest date.
/red-alert/dates.json
  Cache-Control: no-cache

# Daily JSON files — validated on every request (304 Fast if unchanged).
# In-app dayCache handles session-level caching for historical dates;
# the latest date is intentionally never cached so new alerts appear immediately.
/red-alert/*
  Cache-Control: no-cache

# Static real-data files — never change
/real-data/*
  Cache-Control: public, max-age=31536000, immutable

# Vite-fingerprinted JS/CSS assets — immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# RTL text plugin — static library, immutable
/mapbox-gl-rtl-text.js
  Cache-Control: public, max-age=31536000, immutable

# HTML entry point — short cache so deploys propagate quickly
/index.html
  Cache-Control: public, max-age=0, must-revalidate
