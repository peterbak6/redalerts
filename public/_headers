# Red-alert daily JSON files — today's and yesterday's can be rewritten by the
# cron job every 3h; older files are immutable but we can't express that here.
# max-age=10800 matches the cron schedule and covers a typical browsing session,
# so history scrubbing serves files from browser cache without roundtrips.
/red-alert/*
  Cache-Control: public, max-age=10800

# Static real-data files — never change
/real-data/*
  Cache-Control: public, max-age=31536000, immutable

# Vite-fingerprinted JS/CSS assets — immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# RTL text plugin — static library, immutable
/mapbox-gl-rtl-text.js
  Cache-Control: public, max-age=31536000, immutable

# HTML entry point — short cache so deploys propagate quickly
/index.html
  Cache-Control: public, max-age=0, must-revalidate
