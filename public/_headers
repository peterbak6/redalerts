# dates.json is the app's entry point — must always be fresh so first-time
# visitors (no prior cache) land on the correct latest date.
/red-alert/dates.json
  Cache-Control: no-cache

# Historical daily JSON files — immutable once written; long cache is safe.
# The latest date is handled in-app with fetch cache:'no-cache' so the CDN
# header here doesn't matter for freshness — but it keeps history scrubbing fast.
/red-alert/*
  Cache-Control: public, max-age=31536000, immutable

# Static real-data files — never change
/real-data/*
  Cache-Control: public, max-age=31536000, immutable

# Vite-fingerprinted JS/CSS assets — immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# RTL text plugin — static library, immutable
/mapbox-gl-rtl-text.js
  Cache-Control: public, max-age=31536000, immutable

# HTML entry point — short cache so deploys propagate quickly
/index.html
  Cache-Control: public, max-age=0, must-revalidate
